# Supabase configuration
# Create a duplicate in `.env.local` and fill values. NEVER commit your service role key.

# Public values (safe to use in client-side code)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only values (keep secret, do NOT commit to git)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: other environment variables
NEXT_PUBLIC_APP_NAME=NexusAI
